{
  "citations": {
    "bib_files": ["references.bib"],
    // Allowed BibTeX entry types; [] = allow all types:
    "allowed_types": ["book", "article", "inproceedings", "incollection"],
    // Exceptions: a type allowed only for keys with a given prefix, e.g.
    // { "type": "manual", "key_prefix": "xilinx" }
    "type_exceptions": [],
    // Fields every entry of a type MUST carry (anti-fabrication anchor):
    "required_fields": {
      "article": ["doi", "journal", "year", "author", "title"],
      "inproceedings": ["doi", "booktitle", "year", "author", "title"],
      "book": ["publisher", "year", "author", "title"]
    },
    "cite_keys_must_exist": true,   // every \cite / @key must be in a bib file

    // REFERENCES-FIRST POLICY (the shelf): every bib entry must point at
    // a source file the user physically placed in the shelf directory,
    // via a `file = {references/<name>.pdf}` field. You cannot cite what
    // is not on the shelf — a suggested-but-not-downloaded reference
    // cannot enter the bibliography. Pairs with enforcement.web_gate.
    "local_sources": {
      "enabled": true,
      "dir": "references/",
      "severity": "error",
      // Shelf sections: an entry's TYPE binds it to a subdirectory —
      // an @article cannot hide in book/, a datasheet cannot pose as a
      // paper. Types not listed only need to be somewhere under dir.
      "type_dirs": {
        "article":       "references/paper/",
        "inproceedings": "references/paper/",
        "incollection":  "references/paper/",
        "book":          "references/book/",
        "manual":        "references/manual/"
      }
    },
    "verify_online": {
      "enabled": true,               // used by citecheck.py --online (CI)
      "doi_resolver": "crossref",
      "isbn_resolver": "openlibrary",
      "title_match_threshold": 0.75, // fuzzy match fetched title vs bib title
      "cache_days": 90
    }
  }
}
